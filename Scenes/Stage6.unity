--- !u!1001 &933236244
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 452732258147512795, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: m_OnClick.m_PersistentCalls.m_Calls.Array.data[0].m_Mode
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 452732258147512795, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: m_OnClick.m_PersistentCalls.m_Calls.Array.data[0].m_MethodName
      value: RestartGame
      objectReference: {fileID: 0}
    - target: {fileID: 452732258147512795, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: m_OnClick.m_PersistentCalls.m_Calls.Array.data[0].m_Arguments.m_StringArgument
      value: Stage6
      objectReference: {fileID: 0}
    - target: {fileID: 666427164208961391, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: m_text
      value: "\uC81C1\uC7A5\uD77C\uB108\uB9AC\uC544\u3153\u3141\uB2C8 "
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: playerScript
      value: 
      objectReference: {fileID: 375974095}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.size
      value: 11
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[0]
      value: "\uC774\uBC88 \uBCF4\uC2A4\uB294 \uAE30\uBBF9 \uC694\uC18C\uC640 \uB79C\uB364\uD0C4\uC774
        \uC880 \uB9CE\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[1]
      value: "\uB79C\uB364\uD0C4\uC740 \uB2E4\uC18C \uAE4C\uB2E4\uB86D\uC9C0\uB9CC
        \uC9D1\uC911\uD574\uC11C \uBCF4\uBA74 \uC6C1\uB2D8\uD55C\uD14C \uB0A0\uC544\uC624\uB294\uC9C0
        \uBCF4\uC785\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[2]
      value: "\uC81C\uC791\uC790\uD55C\uD14C\uB3C4 \uC774 \uC2A4\uD14C\uC774\uC9C0\uAC00
        \uB108\uBB34 \uC5B4\uB824\uC6E0\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[3]
      value: "\uAE30\uBBF9\uD615 \uD328\uD134\uC740 \uB300\uBD80\uBD84 \uB0A0\uBA39
        \uC218\uB2E8\uC774 \uC874\uC7AC\uD558\uB294 \uAC83 \uAC19\uC544\uC694."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[4]
      value: "\uC774\uBC88 \uC2A4\uD14C\uC774\uC9C0\uB294 \uC5B4\uB514 \uD32C\uAC8C\uC784\uC5D0\uC11C
        \uC601\uAC10\uC744 \uB9CE\uC774 \uBC1B\uC558\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[5]
      value: "\uAE30\uACC4\uC5D0 \uD0C0\uACE0 \uC788\uC73C\uBA74 \uC6C0\uC9C1\uC774\uC9C0\uB97C
        \uBABB\uD558\uB2C8\uAE4C \uCCB4\uB825\uC744 \uC880 \uB192\uAC8C \uC7A1\uC558\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[6]
      value: "\uC774 \uC2A4\uD14C\uC774\uC9C0\uC758 \uD544\uB4DC\uC804\uC744 \uAD6C\uD604\uD558\uB294\uAC74
        \uC544\uBB34\uB798\uB3C4 \uB1CC\uC808\uAC19\uC544\uC11C bgm\uB9CC \uB0A8\uC558\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[7]
      value: "\uC2DC\uC57C\uB97C \uC5B8\uC81C \uC5B4\uB5BB\uAC8C \uC7A1\uC544\uC57C
        \uD560\uC9C0 \uD310\uB2E8\uD558\uB294 \uAE30\uC900\uC744 \uC138\uC6B0\uB294
        \uAC83\uB3C4 \uC88B\uC544\uBCF4\uC785\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[8]
      value: "\uC9C4\uC9DC \uB9C8\uC9C0\uB9C9 \uC2A4\uD14C\uC774\uC9C0\uAC00 \uB9DE\uC73C\uB2C8\uAE50
        \uC870\uAE08\uB9CC \uD798\uB0B4\uC8FC\uC138\uC694!"
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[9]
      value: "\uC0AC\uC2E4 \uD29C\uD1A0\uB9AC\uC5BC \uC2A4\uD14C\uC774\uC9C0\uC5D0
        \uC2A4\uD0E0\uB9AC \uD328\uB7EC\uBE14 \uC694\uC18C\uAC00 \uC870\uAE08 \uC788\uC5C8\uC2B5\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1114699589485912486, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: Texts.Array.data[10]
      value: "\uC6D0\uADFC\uAC10\uC774 \uC798 \uC548\uB290\uAEF4\uC9C8 \uB54C\uB294
        \uC6C0\uC9C1\uC774\uAC70\uB098 \uCE74\uBA54\uB77C\uB97C \uB3CC\uB824\uBCF4\uB294
        \uAC83\uB3C4 \uC88B\uC740 \uBC29\uBC95\uC785\uB2C8\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 1240266701802111546, guid: 8f27ad41290da3c458673f748d71317f, type: 3}
      propertyPath: m_IsActive
      value: 0
